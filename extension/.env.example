# URL of the auth service reachable by the extension.
# With Nginx (docker-compose up):          http://localhost/api/auth
# Without Nginx (standalone / dev):        http://localhost:8080
VITE_AUTH_URL=http://localhost/api/auth

# URL of the blacklist service reachable by the extension.
# With Nginx (docker-compose up):          http://localhost/api/blacklist
# Without Nginx (standalone / dev):        http://localhost:3000
VITE_BLACKLIST_URL=http://localhost/api/blacklist