{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["chrome", "vite/client"]
  },
  "include": [
    "background/**/*.ts",
    "blocked/**/*.ts",
    "popup/**/*.ts",
    "popup/**/*.vue"
  ]
}
