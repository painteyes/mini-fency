# Copy this file to .env and fill in the values before running docker-compose.

# Shared secret used to sign and verify JWT tokens.
JWT_SECRET=change-this-to-a-long-random-secret

# Admin password stored as a bcrypt hash. Default value hashes "password123".
# Single quotes prevents docker-compose from interpolating the $ signs in the hash.
ADMIN_PASSWORD_HASH='$2a$10$AEijIE5MiUt8Ubu3iaE6Xu2b4tymLvjYZpFUzjc4RRESVIvSN98ju'

# Comma-separated list of origins allowed to call the services (CORS).
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ID of the Chrome extension, used by auth-service and blacklist-service to whitelist 
# the chrome-extension:// origin in CORS, and injected into the web-ui at build time.
# Find the ID at chrome://extensions after loading the unpacked extension.
CHROME_EXTENSION_ID=