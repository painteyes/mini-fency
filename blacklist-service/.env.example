# This file is documentation only.
# When using docker-compose, variables are injected automatically from the root .env file.
#
# To run standalone: copy this file to .env and fill in the values.
#
JWT_SECRET=change-this-to-a-long-random-secret # must match the JWT_SECRET used by auth-service
ALLOWED_ORIGINS=http://localhost,http://localhost:5173
PORT=3000