# Backend service URLs proxied automatically by Vite (dev) and nginx (Docker).
VITE_AUTH_BASE_URL=/api/auth
VITE_BLACKLIST_BASE_URL=/api/blacklist

# Extension ID for instant blacklist sync (npm run dev only).
# For Docker, this is injected automatically via docker-compose build args.
# Find the ID at chrome://extensions after loading the unpacked extension.
VITE_EXTENSION_ID=