# This file is documentation only.
# When using docker-compose, variables are injected automatically from the root .env file.
#
# To run standalone: Go does not read .env files automatically.
# Export each variable to your OS environment (e.g. export JWT_SECRET=...).
#
JWT_SECRET=change-this-to-a-long-random-secret # must match the JWT_SECRET used by blacklist-service
ADMIN_PASSWORD_HASH='$2a$10$...' # bcrypt hash of the admin password
ALLOWED_ORIGINS=http://localhost,http://localhost:5173
PORT=8080